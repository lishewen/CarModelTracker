<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarModelTracker.Views.CarModelPage"
             xmlns:vm="clr-namespace:CarModelTracker.ViewModels"
             Title="添加/编辑车模">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="保存" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <!-- 品牌 -->
            <Label Text="品牌 *" FontAttributes="Bold" />
            <Entry Text="{Binding Brand}" Placeholder="例如：AutoArt, Minichamps" />

            <!-- 车型名称 -->
            <Label Text="车型名称 *" FontAttributes="Bold" />
            <Entry Text="{Binding ModelName}" Placeholder="例如：Porsche 911 GT3" />

            <!-- 比例 -->
            <Label Text="比例" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding Scales}"
                    SelectedItem="{Binding Scale}" />

            <!-- 颜色 -->
            <Label Text="颜色" FontAttributes="Bold" />
            <Entry Text="{Binding Color}" Placeholder="例如：红色，蓝色" />

            <!-- 购买日期 -->
            <Label Text="购买日期" FontAttributes="Bold" />
            <DatePicker Date="{Binding PurchaseDate}" />

            <!-- 购买价格 -->
            <Label Text="购买价格" FontAttributes="Bold" />
            <Entry Text="{Binding PurchasePrice}"
                   Placeholder="0.00"
                   Keyboard="Numeric" />

            <!-- 数量 -->
            <Label Text="数量" FontAttributes="Bold" />
            <Entry Text="{Binding Quantity}"
                   Keyboard="Numeric" />

            <!-- 备注 -->
            <Label Text="备注" FontAttributes="Bold" />
            <Editor Text="{Binding Notes}"
                    HeightRequest="100"
                    Placeholder="输入备注信息..." />

            <!-- 保存和取消按钮 -->
            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center" Margin="0,20,0,0">
                <Button Text="保存"
                        Command="{Binding SaveCommand}"
                        Padding="30,10" />
                <Button Text="取消"
                        Command="{Binding CancelCommand}"
                        Padding="30,10"
                        BackgroundColor="Gray" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
