<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarModelTracker.Views.HomePage"
             xmlns:vm="clr-namespace:CarModelTracker.ViewModels"
             Title="车模收藏家"
             BackgroundColor="{StaticResource Background}">

    <!-- 导航栏标题 -->
    <ContentPage.TitleView>
        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
            <Label Text="🚗" FontSize="24" VerticalOptions="Center" />
            <Label Text="车模收藏家" 
                   TextColor="{StaticResource White}" 
                   FontSize="22" 
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </ContentPage.TitleView>

    <Grid RowDefinitions="Auto,Auto,*" BackgroundColor="{StaticResource Background}">
        
        <!-- 顶部统计卡片区域 -->
        <Grid Grid.Row="0" 
              ColumnDefinitions="*,*" 
              ColumnSpacing="12"
              RowDefinitions="Auto,Auto"
              RowSpacing="12"
              Margin="16,16,16,12">
            
            <!-- 收藏总数 -->
            <Frame Grid.Column="0" Grid.Row="0"
                   BackgroundColor="{StaticResource PrimaryLight}"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="收藏总数"
                           TextColor="{StaticResource White}"
                           Opacity="0.8"
                           FontSize="13" />
                    <Label Text="{Binding TotalCount, StringFormat='{0}'}"
                           TextColor="{StaticResource Accent}"
                           FontSize="32"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <!-- 收藏总值 -->
            <Frame Grid.Column="1" Grid.Row="0"
                   BackgroundColor="{StaticResource PrimaryLight}"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="收藏总值"
                           TextColor="{StaticResource White}"
                           Opacity="0.8"
                           FontSize="13" />
                    <Label Text="{Binding TotalValue, StringFormat='¥{0:F2}'}"
                           TextColor="{StaticResource Accent}"
                           FontSize="24"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <!-- 品牌数量 -->
            <Frame Grid.Column="0" Grid.Row="1"
                   BackgroundColor="{StaticResource PrimaryLight}"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="品牌数量"
                           TextColor="{StaticResource White}"
                           Opacity="0.8"
                           FontSize="13" />
                    <Label Text="{Binding BrandCount, StringFormat='{0}'}"
                           TextColor="{StaticResource White}"
                           FontSize="28"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <!-- 本周新增 -->
            <Frame Grid.Column="1" Grid.Row="1"
                   BackgroundColor="{StaticResource PrimaryLight}"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="本周新增"
                           TextColor="{StaticResource White}"
                           Opacity="0.8"
                           FontSize="13" />
                    <Label Text="{Binding WeekAdded, StringFormat='{0}'}"
                           TextColor="{StaticResource White}"
                           FontSize="28"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- 搜索和筛选区域 -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*,Auto" 
              ColumnSpacing="12"
              Margin="16,0">
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource White}"
                    StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    Padding="20,0"
                    Shadow="{StaticResource CardShadow}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Image Grid.Column="0"
                           Source="fontawesome_search.png"
                           WidthRequest="20"
                           HeightRequest="20"
                           VerticalOptions="Center"
                           Opacity="0.5" />
                    <Entry Grid.Column="1"
                           Text="{Binding SearchTerm}"
                           Placeholder="搜索车模名称、品牌、型号..."
                           ReturnCommand="{Binding SearchCommand}"
                           BackgroundColor="Transparent"
                           Margin="0,12,0,12" />
                </Grid>
            </Border>
            
            <Border Grid.Column="1"
                    BackgroundColor="{StaticResource White}"
                    StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    Padding="16"
                    Shadow="{StaticResource CardShadow}">
                <Image Source="fontawesome_filter.png"
                       WidthRequest="24"
                       HeightRequest="24"
                       VerticalOptions="Center"
                       HorizontalOptions="Center" />
            </Border>
        </Grid>

        <!-- 车模列表/空状态 -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding CarModels}"
                        RefreshCommand="{Binding LoadDataCommand}"
                        IsRefreshing="{Binding IsRefreshing}"
                        IsPullToRefreshEnabled="True"
                        SelectionMode="None"
                        Margin="16,12">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="40" Spacing="20" VerticalOptions="Center">
                    <Label Text="🚗"
                           FontSize="64"
                           HorizontalOptions="Center"
                           Opacity="0.3" />
                    <Label Text="暂无车模收藏"
                           FontSize="18"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" />
                    <Button Text="添加第一个车模"
                            Command="{Binding AddNewCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="12"
                            Padding="30,14"
                            FontSize="16"
                            HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="{StaticResource CardBackground}"
                           CornerRadius="12"
                           HasShadow="True"
                           Padding="16"
                           Margin="0,6">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Brand}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding ModelName}"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Frame BackgroundColor="{StaticResource PrimaryLighter}"
                                           Padding="8,4"
                                           CornerRadius="6"
                                           HasShadow="False">
                                        <Label Text="{Binding Scale}"
                                               FontSize="12"
                                               TextColor="{StaticResource Primary}" />
                                    </Frame>
                                    <Label Text="{Binding Color}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding PurchasePrice, StringFormat='¥{0:F2}'}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Accent}" />
                            </VerticalStackLayout>
                            
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="8"
                                                   VerticalOptions="Center">
                                <Button Text="编辑"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource Primary}"
                                        CornerRadius="8"
                                        Padding="16,10" />
                                <Button Text="删除"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource Error}"
                                        CornerRadius="8"
                                        Padding="16,10" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
