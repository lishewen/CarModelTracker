<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarModelTracker.Views.SettingsPage"
             xmlns:vm="clr-namespace:CarModelTracker.ViewModels"
             Title="设置"
             BackgroundColor="{StaticResource Background}">

    <!-- 导航栏标题 -->
    <ContentPage.TitleView>
        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
            <Label Text="⚙️" FontSize="24" VerticalOptions="Center" />
            <Label Text="设置" 
                   TextColor="{StaticResource White}" 
                   FontSize="22" 
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </ContentPage.TitleView>

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Padding="16" Spacing="16">
            
            <!-- 导出 Excel 卡片 -->
            <Frame BackgroundColor="{StaticResource CardBackground}"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="16">
                <VerticalStackLayout Spacing="16">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⬇️" 
                               FontSize="20"
                               VerticalOptions="Center" />
                        <Label Text="导出 Excel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- 导出范围 -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="导出范围"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />
                        
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="全部车模 (0)"
                                    BackgroundColor="{StaticResource Primary}"
                                    CornerRadius="12"
                                    Padding="16,12" />
                            <Button Grid.Column="1"
                                    Text="当前筛选结果"
                                    BackgroundColor="{StaticResource Gray100}"
                                    TextColor="{StaticResource TextSecondary}"
                                    CornerRadius="12"
                                    Padding="16,12" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- 导出字段 -->
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="导出字段"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="12">
                                <Label Text="全选"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectAllFieldsCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <BoxView WidthRequest="1"
                                         HeightRequest="16"
                                         BackgroundColor="{StaticResource Gray300}"
                                         VerticalOptions="Center" />
                                <Label Text="取消"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding DeselectAllFieldsCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- 字段复选框网格 -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.Name}" Color="{StaticResource Primary}" />
                                <Label Text="名称" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.Brand}" Color="{StaticResource Primary}" />
                                <Label Text="品牌" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.Model}" Color="{StaticResource Primary}" />
                                <Label Text="型号" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.Scale}" Color="{StaticResource Primary}" />
                                <Label Text="比例" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.Quantity}" Color="{StaticResource Primary}" />
                                <Label Text="数量" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.Price}" Color="{StaticResource Primary}" />
                                <Label Text="单价" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="3" Grid.Column="0" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.TotalPrice}" Color="{StaticResource Primary}" />
                                <Label Text="总价" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Row="3" Grid.Column="1" Spacing="8">
                                <CheckBox IsChecked="{Binding ExportFields.PurchaseDate}" Color="{StaticResource Primary}" />
                                <Label Text="购买日期" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- 导出按钮 -->
                    <Button Text="导出 CSV 文件"
                            Command="{Binding ExportCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="12"
                            Padding="16,12"
                            FontSize="16">
                        <Button.ImageSource>
                            <FontImageSource Glyph="⬇️"
                                            Size="20"
                                            Color="{StaticResource White}" />
                        </Button.ImageSource>
                    </Button>
                </VerticalStackLayout>
            </Frame>

            <!-- 关于卡片 -->
            <Frame BackgroundColor="{StaticResource CardBackground}"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="16">
                <VerticalStackLayout Spacing="16">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="ℹ️" 
                               FontSize="20"
                               VerticalOptions="Center" />
                        <Label Text="关于"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="应用名称"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="车模收藏家"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="版本"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="1.0.0"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
