<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarModelTracker.Views.MainPage"
             xmlns:vm="clr-namespace:CarModelTracker.ViewModels"
             Title="车模收藏"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="统计" 
                     Command="{Binding NavigateToStatisticsCommand}"
                     IconImageSource="fontawesome_ellipsis_vertical.png" />
        <ToolbarItem Text="导出" 
                     Command="{Binding ExportCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
        
        <!-- 搜索区域 -->
        <Border Grid.Row="0" 
                Style="{StaticResource SearchBarCard}"
                Margin="16,16,16,0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Image Grid.Column="0"
                       Source="fontawesome_search.png"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center"
                       Margin="12,0,0,0" />
                <Entry Grid.Column="0"
                       Text="{Binding SearchTerm}"
                       Placeholder="搜索品牌或车型..."
                       ReturnCommand="{Binding SearchCommand}"
                       Margin="36,12,0,12" />
                <Button Grid.Column="1"
                        Text="搜索"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource IconButton}"
                        Margin="8" />
            </Grid>
        </Border>

        <!-- 筛选区域 -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*,Auto" 
              ColumnSpacing="12"
              Margin="16,0">
            <Border Grid.Column="0"
                    Style="{StaticResource SearchBarCard}">
                <Picker ItemsSource="{Binding Scales}"
                        SelectedItem="{Binding SelectedScaleFilter}"
                        Title="按比例筛选"
                        Margin="12,0" />
            </Border>
            <Button Grid.Column="1"
                    Text="筛选"
                    Command="{Binding FilterByScaleCommand}"
                    Style="{StaticResource SecondaryButton}"
                    MinimumWidthRequest="80" />
        </Grid>

        <!-- 状态消息 -->
        <Label Grid.Row="1"
               Text="{Binding StatusMessage}"
               Style="{StaticResource Caption}"
               Margin="16,8,16,0"
               VerticalOptions="End" />

        <!-- 车模列表 -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding CarModels}"
                        RefreshCommand="{Binding LoadDataCommand}"
                        IsRefreshing="{Binding IsRefreshing}"
                        IsPullToRefreshEnabled="True"
                        SelectionMode="None"
                        EmptyView="暂无车模记录，点击右上角添加">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource ListItemCard}"
                           Margin="16,6">
                        <Grid ColumnDefinitions="*,Auto" 
                              ColumnSpacing="16"
                              Padding="16">
                            
                            <!-- 左侧信息区 -->
                            <VerticalStackLayout Grid.Column="0" 
                                                 Spacing="8"
                                                 VerticalOptions="Center">
                                
                                <!-- 品牌和车型 -->
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Brand}"
                                           Style="{StaticResource Subtitle}"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding ModelName}"
                                           Style="{StaticResource Body}"
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                                
                                <!-- 比例和颜色标签 -->
                                <HorizontalStackLayout Spacing="8">
                                    <Frame BackgroundColor="{StaticResource PrimaryLight}"
                                           Padding="8,4"
                                           CornerRadius="6"
                                           HasShadow="False">
                                        <Label Text="{Binding Scale}"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource Primary}" />
                                    </Frame>
                                    <Frame BackgroundColor="{StaticResource Gray100}"
                                           Padding="8,4"
                                           CornerRadius="6"
                                           HasShadow="False">
                                        <Label Text="{Binding Color}"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </Frame>
                                </HorizontalStackLayout>
                                
                                <!-- 购买信息和数量 -->
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="购买日期"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource TextDisabled}" />
                                        <Label Text="{Binding PurchaseDate, StringFormat='{0:yyyy-MM-dd}'}"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="单价"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource TextDisabled}" />
                                        <Label Text="{Binding PurchasePrice, StringFormat='¥{0:F0}'}"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="2">
                                        <Label Text="数量"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource TextDisabled}" />
                                        <Label Text="{Binding Quantity}"
                                               Style="{StaticResource Caption}"
                                               TextColor="{StaticResource Secondary}"
                                               FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Grid>
                                
                                <!-- 总价值 -->
                                <BoxView HeightRequest="1" 
                                         BackgroundColor="{StaticResource Gray200}"
                                         Margin="0,4" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="总价值:"
                                           Style="{StaticResource Caption}"
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Label Text="{Binding TotalValue, StringFormat='¥{0:F2}'}"
                                           Style="{StaticResource Caption}"
                                           TextColor="{StaticResource Success}"
                                           FontAttributes="Bold" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- 右侧操作按钮 -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="8"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="End">
                                <Button Text="编辑"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="16,10"
                                        FontSize="13" />
                                <Button Text="删除"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        Style="{StaticResource DangerButton}"
                                        Padding="16,10"
                                        FontSize="13" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <!-- 悬浮添加按钮 -->
        <Button Grid.Row="2"
                Command="{Binding AddNewCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="{StaticResource White}"
                Text="+"
                FontSize="28"
                FontAttributes="Bold"
                CornerRadius="28"
                WidthRequest="56"
                HeightRequest="56"
                Padding="0"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="24">
            <Button.Shadow>
                <Shadow Brush="{StaticResource Primary}"
                        Offset="0,4"
                        Radius="12"
                        Opacity="0.4" />
            </Button.Shadow>
        </Button>
    </Grid>
</ContentPage>
